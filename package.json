{
  "name": "iobroker.eebus-go",
  "version": "0.0.1",
  "description": "eebus grpc client for a hems",
  "author": {
    "name": "FernetMenta",
    "email": "fernetmenta@online.de"
  },
  "contributors": [],
  "homepage": "https://github.com/FernetMenta/ioBroker.eebus-go",
  "license": "GPL-3.0",
  "keywords": [
    "eebus",
    "eebus-go",
    "iobroker",
    "hems"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/FernetMenta/ioBroker.eebus-go.git"
  },
  "engines": {
    "node": ">= 20"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.4.1",
    "javascript-state-machine": "^3.1.0"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.2.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.2.0",
    "@alcalzone/release-script-plugin-license": "^5.2.0",
    "@alcalzone/release-script-plugin-manual-review": "^5.2.0",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/build-tools": "^3.0.1",
    "@iobroker/dev-server": "^0.8.0",
    "@iobroker/eslint-config": "^2.3.4",
    "@iobroker/testing": "^5.2.2",
    "@sinonjs/referee-sinon": "^12.0.1",
    "@tsconfig/node20": "^20.1.9",
    "@types/iobroker": "npm:@iobroker/types@^7.2.2",
    "@types/node": "^20.19.43",
    "coffee-script": "^1.12.7",
    "globals": "^17.6.0",
    "jsverify": "^0.8.4",
    "knuth-shuffle": "^1.0.8",
    "typescript": "~5.9.3"
  },
  "main": "main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).{json,json5}",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "lib/",
    "www/",
    "io-package.json",
    "LICENSE",
    "main.js"
  ],
  "scripts": {
    "test:js": "mocha --config test/mocharc.custom.json \"{!(node_modules|test)/**/*.test.js,*.test.js,test/**/test!(PackageFiles|Startup).js}\"",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:js && npm run test:package",
    "check": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint -c eslint.config.mjs .",
    "translate": "translate-adapter",
    "release": "release-script",
    "dev-server": "dev-server",
    "0-clean": "node tasks --0-clean",
    "1-npm": "node tasks --1-npm",
    "2-build": "node tasks --2-build",
    "3-copy": "node tasks --3-copy",
    "4-patch": "node tasks --4-patch",
    "build": "node tasks"
  },
  "bugs": {
    "url": "https://github.com/FernetMenta/ioBroker.eebus-go/issues"
  },
  "readmeFilename": "README.md"
}
